{
  "name": "capsule",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "dependencies": {
    "@expo/ui": "~56.0.15",
    "babel-plugin-inline-import": "^3.0.0",
    "drizzle-orm": "^0.45.2",
    "expo": "~56.0.8",
    "expo-constants": "~56.0.17",
    "expo-device": "~56.0.4",
    "expo-drizzle-studio-plugin": "^0.2.1",
    "expo-font": "~56.0.5",
    "expo-glass-effect": "~56.0.4",
    "expo-image": "~56.0.9",
    "expo-linking": "~56.0.13",
    "expo-router": "~56.2.9",
    "expo-splash-screen": "~56.0.10",
    "expo-sqlite": "~56.0.4",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.5",
    "expo-system-ui": "~56.0.5",
    "expo-web-browser": "~56.0.5",
    "llama.rn": "^0.12.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-mmkv": "^4.3.1",
    "react-native-nitro-modules": "^0.35.9",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-unistyles": "^3.2.5",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3",
    "whisper.rn": "^0.6.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.2",
    "better-sqlite3": "^12.11.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~56.0.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-prettier": "^5.5.6",
    "expo-mcp": "~0.2.1",
    "jest-expo": "^56.0.5",
    "prettier": "^3.8.3",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFiles": [
      "llama.rn/jest/mock"
    ],
    "moduleNameMapper": {
      "^react-native-mmkv$": "<rootDir>/src/__mocks__/react-native-mmkv.ts",
      "^expo-sqlite$": "<rootDir>/src/__mocks__/expo-sqlite.ts",
      "^expo-file-system$": "<rootDir>/src/__mocks__/expo-file-system.ts"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|native-base|react-native-svg|drizzle-orm|react-native-mmkv|llama.rn|whisper.rn|react-native-unistyles|react-native-reanimated|react-native-nitro-modules)"
    ],
    "testMatch": [
      "<rootDir>/src/**/__tests__/**/*.test.(ts|tsx)"
    ]
  },
  "private": true
}
